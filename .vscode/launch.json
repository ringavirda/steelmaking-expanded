{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vintagestory Client",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${env:VINTAGE_STORY}/Vintagestory.dll",
      "args": [
        "--tracelog",
        "--addModPath",
        "${workspaceFolder}/SteelmakingExpanded/bin/Debug/Mods",
        "--addOrigin",
        "${workspaceFolder}/SteelmakingExpanded/assets"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole",
      "requireExactSource": false
    }
  ]
}