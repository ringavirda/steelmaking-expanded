        </mxCell>
        <mxCell id="N3N-RfWJmq3yOfmEteNa-112" parent="N3N-RfWJmq3yOfmEteNa-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="All excess fluids/gases on this diagram are simply dumped on the ground/in the atmosphere.&lt;div&gt;Pipe opening (uncovered pipe end) can expell 8l/s of gas or 1l/s of fluid (water).&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="160" x="-180" y="1200" as="geometry" />
        </mxCell>
        <mxCell id="N3N-RfWJmq3yOfmEteNa-113" parent="N3N-RfWJmq3yOfmEteNa-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Starter steel production setup&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="180" x="-795" y="490" as="geometry" />
