        <mxCell id="pWUfct4_YDeaPmcj9MpU-73" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Cowper stoves are operated manually through valves. They&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;lower the temp of incoming exhaust, accumulating it inside, and heat up incoming air, retaining pressure.&amp;nbsp;&amp;nbsp;&lt;/span&gt;" vertex="1">
