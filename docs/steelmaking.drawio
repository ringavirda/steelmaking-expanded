        </mxCell>
        <mxCell id="pWUfct4_YDeaPmcj9MpU-76" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Kickstart this boiler manually with buckets" vertex="1">
          <mxGeometry height="40" width="100" x="20" y="560" as="geometry" />
        </mxCell>
        <mxCell id="pWUfct4_YDeaPmcj9MpU-77" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="There cannot be more water in the pipe than it can contain (water doesn&#39;t compact like gas does). When water reaches capacity in pipe, it&#39;s pressure becomes equal to the pumping engine incoming steam pressure * 0.7 (steam engine efficiency)." vertex="1">
          <mxGeometry height="110" width="205" x="405" y="1140" as="geometry" />
        </mxCell>
        <mxCell id="pWUfct4_YDeaPmcj9MpU-78" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="If boiler recieves water with pressure more than 1 atm, that pressure gets added to internal steam pressure." vertex="1">
          <mxGeometry height="100" width="110" x="100" y="1200" as="geometry" />
        </mxCell>
